# monitor-grafana — environment variables template
#
# Copy this file to .env (gitignored) and fill in your real values.
# Every variable here has a sensible default in docker-compose.yml; you only
# need to override the ones that matter for your environment.

# --- Postgres (monitor database) ---
POSTGRES_DB=monitoring
POSTGRES_USER=monitoring
POSTGRES_PASSWORD=change-me

# Exposed host port for the Postgres container (container port is fixed at 5432).
POSTGRES_HOST_PORT=5433

# Internal hostname/port the exporter uses to reach Postgres.
# Override when pointing at an EXTERNAL Postgres instead of the bundled
# `postgres` container (e.g. managed RDS / Cloud SQL).
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Grafana ---
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin

# Datasource connection used by Grafana provisioning (usually same as the
# Postgres values above).
DS_POSTGRES_HOST=postgres
DS_POSTGRES_PORT=5432
DS_POSTGRES_DATABASE=monitoring
DS_POSTGRES_USER=monitoring
DS_POSTGRES_PASSWORD=change-me

# Per-lab Postgres datasources (optional, for the DB Observability dashboard).
DS_POSTGRES_DEMO_A_HOST=pg.demo-lab-a.example.com
DS_POSTGRES_DEMO_A_PORT=5432
DS_POSTGRES_DEMO_A_USER=monitor_ro
GF_DS_POSTGRES_DEMO_A_PASSWORD=change-me

DS_POSTGRES_DEMO_B_HOST=pg.demo-lab-b.example.com
DS_POSTGRES_DEMO_B_PORT=5432
DS_POSTGRES_DEMO_B_USER=monitor_ro
GF_DS_POSTGRES_DEMO_B_PASSWORD=change-me

# Per-lab MySQL datasources (optional, for the MySQL Observability dashboard).
DS_MYSQL_DEMO_A_HOST=mysql.demo-lab-a.example.com
DS_MYSQL_DEMO_A_PORT=3306
DS_MYSQL_DEMO_A_USER=monitor_ro
GF_DS_MYSQL_DEMO_A_PASSWORD=change-me

# --- Admin UI (port 9119) ---
# The admin UI delegates auth to Grafana — the URLs below tell it where to
# call /api/user (internal) and where to redirect the browser to log in (public).
GRAFANA_INTERNAL_URL=http://grafana:3000
GRAFANA_PUBLIC_URL=http://localhost:3000
ADMIN_UI_SECRET_KEY=generate-with-python-secrets-token_urlsafe-32

# Optional Grafana service-account token used by the datasource_sync background
# job. If unset, it falls back to the GF_SECURITY_ADMIN_* basic auth above.
GRAFANA_SA_TOKEN=

# --- Optional overrides (all have sensible defaults in the code) ---
# ADMIN_UI_PORT=9119           # change only if 9119 collides with something
# PROMETHEUS_URL=http://prometheus:9090   # used by log_blackbox_results

# Host-side port overrides — flip when something else on the host already
# holds the default port (e.g. another Grafana / Prometheus stack running).
GRAFANA_HOST_PORT=3000
PROMETHEUS_HOST_PORT=9090

# --- SMTP relay (Grafana alert notifications) ---
# Set GF_SMTP_ENABLED=true to actually send emails; defaults to false so the
# stack starts cleanly without an SMTP relay configured.
GF_SMTP_ENABLED=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_FROM=monitoring@example.com
SMTP_STARTTLS_POLICY=OpportunisticStartTLS
SMTP_USER=
SMTP_PASSWORD=
