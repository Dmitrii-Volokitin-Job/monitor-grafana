      "title": "24h Uptime",
      "type": "gauge",
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "monitor-postgres"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT 100.0 * SUM(CASE WHEN h.status='UP' THEN 1 ELSE 0 END) / NULLIF(COUNT(*),0) AS uptime FROM health_check_history h JOIN monitored_system ms ON ms.id = h.system_id WHERE h.check_timestamp >= NOW() - INTERVAL '24 hour' AND ('$system_group' = '.*' OR ms.system_group = ANY(string_to_array('$system_group', ',')))",
          "refId": "A"
        }
      ]
