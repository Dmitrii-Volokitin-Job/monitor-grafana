      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "monitor-postgres"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT ms.display_name AS \"System\", ms.system_group AS \"Group\", ms.system_id AS \"ID\", ms.system_type AS \"Type\", ms.url AS \"URL\", 100.0 * SUM(CASE WHEN h.status='UP' THEN 1 ELSE 0 END) / NULLIF(COUNT(*),0) AS \"Uptime %\", AVG(NULLIF(h.response_time_ms,0))/1000.0 AS \"Avg Response\" FROM health_check_history h JOIN monitored_system ms ON ms.id = h.system_id WHERE h.check_timestamp >= NOW() - INTERVAL '7 day' AND ('$system_group' = '.*' OR ms.system_group = ANY(string_to_array('$system_group', ','))) GROUP BY ms.id, ms.display_name, ms.system_group, ms.system_id, ms.system_type, ms.url HAVING COUNT(*) > 0 ORDER BY \"Uptime %\" ASC LIMIT 10",
          "refId": "A"
        }
      ]
