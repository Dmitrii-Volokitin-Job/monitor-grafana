          "rawSql": "SELECT $__timeGroup(h.check_timestamp, 1h) AS time, ms.system_group AS metric, 100.0 * SUM(CASE WHEN h.status='UP' THEN 1 ELSE 0 END) / NULLIF(COUNT(*),0) AS value FROM health_check_history h JOIN monitored_system ms ON ms.id = h.system_id WHERE $__timeFilter(h.check_timestamp) AND ('$system_group' = '.*' OR ms.system_group = ANY(string_to_array('$system_group', ','))) GROUP BY time, ms.system_group ORDER BY time",
