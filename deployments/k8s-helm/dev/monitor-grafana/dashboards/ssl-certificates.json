      },
      "id": 110,
      "title": "TLS & Certificate Details",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "monitor-prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "inspect": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "semi-dark-green",
                "value": null
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "TLS Version"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "options": {
                      "pattern": ".*1\\.3.*",
                      "result": {
                        "color": "semi-dark-green",
                        "text": "TLS 1.3"
                      }
                    },
                    "type": "regex"
                  },
                  {
                    "options": {
                      "pattern": ".*1\\.2.*",
                      "result": {
                        "color": "semi-dark-yellow",
                        "text": "TLS 1.2"
                      }
                    },
                    "type": "regex"
                  },
                  {
                    "options": {
                      "pattern": ".*1\\.1.*",
                      "result": {
                        "color": "semi-dark-orange",
                        "text": "TLS 1.1 (deprecated)"
                      }
                    },
                    "type": "regex"
                  },
                  {
                    "options": {
                      "pattern": ".*1\\.0.*",
                      "result": {
                        "color": "semi-dark-red",
                        "text": "TLS 1.0 (insecure)"
                      }
                    },
                    "type": "regex"
                  }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              },
              {
                "id": "custom.width",
                "value": 140
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Probe OK"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "options": {
                      "0": {
                        "color": "semi-dark-red",
                        "text": "FAIL"
                      },
                      "1": {
                        "color": "semi-dark-green",
                        "text": "OK"
                      }
                    },
                    "type": "value"
                  }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              },
              {
                "id": "custom.width",
                "value": 80
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 34
      },
      "id": 30,
      "options": {
        "cellHeight": "sm",
        "showHeader": true,
        "sortBy": [
          {
            "desc": false,
            "displayName": "Host:Port"
          }
        ]
      },
      "title": "TLS Version & Probe Status",
      "description": "Shows TLS version negotiated for each endpoint and whether the SSL probe succeeded",
      "type": "table",
      "targets": [
