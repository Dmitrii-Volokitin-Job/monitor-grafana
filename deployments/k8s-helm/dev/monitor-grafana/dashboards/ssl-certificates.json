    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "id": 108,
      "title": "Certificates Requiring Attention",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "monitor-prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "inspect": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "semi-dark-green",
                "value": null
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Days Left"
            },
            "properties": [
              {
                "id": "decimals",
                "value": 0
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "semi-dark-red",
                      "value": null
                    },
                    {
                      "color": "semi-dark-orange",
                      "value": 7
                    },
                    {
                      "color": "semi-dark-yellow",
                      "value": 30
                    }
                  ]
                }
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              },
              {
                "id": "custom.width",
                "value": 100
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Expires On"
            },
            "properties": [
              {
                "id": "unit",
                "value": "dateTimeAsIso"
              },
              {
                "id": "custom.width",
                "value": 180
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Urgency"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "options": {
                      "from": -999999,
                      "to": 0,
                      "result": {
                        "color": "semi-dark-red",
                        "text": "EXPIRED"
                      }
                    },
                    "type": "range"
                  },
                  {
                    "options": {
                      "from": 0.001,
                      "to": 7,
                      "result": {
                        "color": "semi-dark-red",
                        "text": "CRITICAL"
                      }
                    },
                    "type": "range"
                  },
                  {
                    "options": {
                      "from": 7.001,
                      "to": 30,
                      "result": {
                        "color": "semi-dark-orange",
                        "text": "WARNING"
                      }
                    },
                    "type": "range"
                  },
                  {
                    "options": {
                      "from": 30.001,
                      "to": 999999,
                      "result": {
                        "color": "semi-dark-green",
                        "text": "OK"
                      }
                    },
                    "type": "range"
                  }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-text"
                }
              },
              {
                "id": "custom.width",
                "value": 100
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 7,
        "w": 24,
        "x": 0,
        "y": 6
      },
      "id": 25,
      "options": {
        "cellHeight": "sm",
        "showHeader": true,
        "sortBy": [
          {
            "desc": false,
            "displayName": "Days Left"
          }
        ]
      },
      "title": "Certificates Expiring Within 90 Days or Expired",
      "description": "Certs expiring within 90 days. Below 30 \u2192 urgent, below 7 \u2192 critical.",
      "type": "table",
      "links": [
        {
          "title": "Back to System Health Overview",
          "url": "/d/monitor-health-overview/system-health-overview?${__url_time_range}&${__all_variables}",
          "targetBlank": false
        }
      ],
      "targets": [
        {
          "expr": "(probe_ssl_earliest_cert_expiry{job=\"blackbox_http\", system_group=~\"$system_group\"} - time()) / 86400 < 90",
          "format": "table",
          "instant": true,
          "refId": "A"
        },
        {
          "expr": "probe_ssl_earliest_cert_expiry{job=\"blackbox_http\", system_group=~\"$system_group\"} * ((probe_ssl_earliest_cert_expiry{job=\"blackbox_http\", system_group=~\"$system_group\"} - time()) / 86400 < 90)",
          "format": "table",
          "instant": true,
          "refId": "B"
        }
      ],
      "transformations": [
        {
          "id": "seriesToColumns",
          "options": {
            "byField": "instance"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time 1": true,
              "Time 2": true,
              "__name__ 1": true,
              "__name__ 2": true,
              "job 1": true,
              "job 2": true,
              "display_name 2": true,
              "system_id 2": true
            },
            "renameByName": {
              "system_id 1": "ID",
              "display_name 1": "System",
              "instance": "Host:Port",
              "Value #A": "Days Left",
              "Value #B": "Expires On"
            }
          }
        },
        {
          "id": "calculateField",
          "options": {
            "alias": "Urgency",
            "mode": "reduceRow",
            "reduce": {
              "reducer": "min",
              "include": [
                "Days Left"
              ]
            }
          }
        }
      ]
    },
