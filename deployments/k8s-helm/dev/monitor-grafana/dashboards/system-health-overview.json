      "title": "Recent Health Check Logs",
      "description": "Check results logged to Postgres every 5 minutes. Shows all Monitor Exporter checks (LDAP, Keycloak, Database). Filtered by dashboard time range and environment group.",
      "type": "table",
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "monitor-postgres"
          },
          "format": "table",
          "rawSql": "SELECT\n  hch.check_timestamp AS \"Time\",\n  ms.display_name AS \"System\",\n  ms.system_group AS \"Group\",\n  ms.system_type AS \"Type\",\n  hch.status AS \"Status\",\n  hch.response_time_ms AS \"Response\",\n  hch.error_message AS \"Error\"\nFROM health_check_history hch\nJOIN monitored_system ms ON hch.system_id = ms.id\nWHERE $__timeFilter(hch.check_timestamp)\n  AND ('$system_group' = '.*' OR ms.system_group = ANY(string_to_array('$system_group', ',')))\n  AND ('$health_status' = '>= 0'\n       OR ('$health_status' = '== 1' AND hch.status = 'UP')\n       OR ('$health_status' = '== 0' AND hch.status = 'DOWN'))\nORDER BY hch.check_timestamp DESC\nLIMIT $log_rows",
          "refId": "A"
        }
      ]
    },
