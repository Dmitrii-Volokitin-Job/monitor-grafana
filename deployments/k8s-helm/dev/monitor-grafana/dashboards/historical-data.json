            "displayName": "sent_timestamp"
          }
        ]
      },
      "title": "Email Audit Trail",
      "type": "table",
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "monitor-postgres"
          },
          "format": "table",
          "rawSql": "SELECT\n  el.sent_timestamp,\n  el.subject,\n  el.to_recipients,\n  el.email_type,\n  el.status,\n  el.retry_count,\n  el.error_message\nFROM email_log el\nLEFT JOIN monitored_system ms ON el.related_system_id = ms.id\nWHERE el.sent_timestamp >= NOW() - INTERVAL '90 day'\n  AND (1=1 OR el.related_system_id IS NULL)\n  AND 1=1\nORDER BY el.sent_timestamp DESC\nLIMIT 500",
          "refId": "A"
        }
      ]
