      "title": "Upcoming & Active Maintenance Windows",
      "description": "Scheduled maintenance windows that are currently active or upcoming",
      "type": "table",
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "monitor-postgres"
          },
          "format": "table",
          "rawSql": "SELECT\n  mw.title,\n  mw.maintenance_type AS type,\n  mw.start_time,\n  mw.end_time,\n  CASE WHEN NOW() BETWEEN mw.start_time AND mw.end_time THEN 'ACTIVE' ELSE 'UPCOMING' END AS status,\n  STRING_AGG(ms.display_name, ', ') AS affected_systems\nFROM maintenance_window mw\nLEFT JOIN maintenance_window_system mws ON mw.id = mws.maintenance_window_id\nLEFT JOIN monitored_system ms ON mws.system_id = ms.id\nWHERE mw.end_time >= NOW()\n  AND mw.is_cancelled = 0\n  AND (1=1 OR ms.system_group IS NULL)\nGROUP BY mw.id\nORDER BY mw.start_time ASC\nLIMIT 20",
          "refId": "A"
        }
      ]
    }
