      "title": "Health Check History (Postgres)",
      "type": "row"
    },
    {
      "datasource": {
        "type": "postgres",
        "uid": "monitor-postgres"
      },
      "description": "Health check results from the Java application, stored in Postgres. This data ages out after 90 days per the retention policy.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": true,
            "stacking": {
              "group": "A",
              "mode": "none"
            }
          },
          "mappings": [
            {
              "options": {
                "UP": {
                  "color": "semi-dark-green",
                  "index": 0
                },
                "DOWN": {
                  "color": "semi-dark-red",
                  "index": 1
                }
              },
              "type": "value"
            }
          ],
          "min": 0,
          "max": 1
        }
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 1
      },
      "id": 1,
      "options": {
        "legend": {
          "calcs": [],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "title": "Health Check Status Over Time",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "monitor-postgres"
          },
          "format": "time_series",
          "rawSql": "SELECT\n  hch.check_timestamp AS time,\n  CASE hch.status WHEN 'UP' THEN 1 ELSE 0 END AS value,\n  ms.display_name AS metric\nFROM health_check_history hch\nJOIN monitored_system ms ON hch.system_id = ms.id\nWHERE\n  1=1\n\n  AND hch.check_timestamp >= $__timeFrom()\n  AND hch.check_timestamp <= $__timeTo()\nORDER BY hch.check_timestamp ASC",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "postgres",
        "uid": "monitor-postgres"
      },
