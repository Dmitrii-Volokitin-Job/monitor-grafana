      "title": "Active Alerts",
      "description": "Currently active alerts from alert_state table. Shows systems that are currently DOWN.",
      "type": "table",
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "monitor-postgres"
          },
          "format": "table",
          "rawSql": "SELECT\n  ast.last_status_change,\n  ms.display_name AS system_name,\n  ms.system_group,\n  ast.current_severity AS severity,\n  ast.current_status AS status,\n  ast.down_since,\n  ast.alert_count\nFROM alert_state ast\nJOIN monitored_system ms ON ast.system_id = ms.id\nWHERE 1=1\n\n  AND ast.current_status = 'DOWN'\nORDER BY ast.down_since DESC\nLIMIT 100",
          "refId": "A"
        }
      ]
    },
