      "title": "Current Alert Duration by Group",
      "description": "Average and maximum downtime duration for currently active alerts, grouped by environment",
      "type": "table",
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "monitor-postgres"
          },
          "format": "table",
          "rawSql": "SELECT\n  ms.system_group AS \"Group\",\n  COUNT(*) AS \"Active Alerts\",\n  ROUND(AVG(EXTRACT(EPOCH FROM (NOW() - ast.down_since))/60), 1) AS \"Avg Downtime (min)\",\n  MAX(EXTRACT(EPOCH FROM (NOW() - ast.down_since))/60) AS \"Max Downtime (min)\"\nFROM alert_state ast\nJOIN monitored_system ms ON ast.system_id = ms.id\nWHERE ast.current_status = 'DOWN'\n  AND 1=1\n\nGROUP BY ms.system_group\nORDER BY AVG(EXTRACT(EPOCH FROM (NOW() - ast.down_since))/60) DESC",
          "refId": "A"
        }
      ]
    },
