      "title": "Response Time History",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "monitor-postgres"
          },
          "format": "time_series",
          "rawSql": "SELECT\n  hch.check_timestamp AS time,\n  hch.response_time_ms AS value,\n  ms.display_name AS metric\nFROM health_check_history hch\nJOIN monitored_system ms ON hch.system_id = ms.id\nWHERE\n  1=1\n\n  AND hch.check_timestamp >= $__timeFrom()\n  AND hch.check_timestamp <= $__timeTo()\n  AND hch.response_time_ms IS NOT NULL\nORDER BY hch.check_timestamp ASC",
          "refId": "A"
        }
      ]
    },
