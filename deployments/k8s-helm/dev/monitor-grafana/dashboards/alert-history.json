          },
          {
            "matcher": {
              "id": "byName",
              "options": "sent_timestamp"
            },
            "properties": [
              {
                "id": "unit",
                "value": "dateTimeAsIso"
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 23
      },
      "id": 10,
      "options": {
        "cellHeight": "sm",
        "showHeader": true,
        "sortBy": [
          {
            "desc": true,
            "displayName": "sent_timestamp"
          }
        ]
      },
      "title": "Email Log",
      "type": "table",
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "monitor-postgres"
          },
          "format": "table",
          "rawSql": "SELECT\n  el.sent_timestamp,\n  el.subject,\n  el.to_recipients,\n  el.status,\n  el.email_type,\n  el.error_message\nFROM email_log el\nLEFT JOIN monitored_system ms ON el.related_system_id = ms.id\nWHERE el.sent_timestamp >= NOW() - INTERVAL '30 day'\n  AND (1=1 OR el.related_system_id IS NULL)\n  AND 1=1\nORDER BY el.sent_timestamp DESC\nLIMIT 200",
          "refId": "A"
        }
      ]
    }
  ],
